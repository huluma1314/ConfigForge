# Sub Store Admin 环境变量模板
# 复制为 .env.local 并填入真实值（.env.local 已加入 .gitignore，不会提交）

# 服务监听
PORT=8789
HOST=127.0.0.1

# 公网访问入口（通过 Cloudflare Tunnel）
SUB_STORE_ADMIN_PUBLIC_ORIGIN=https://subadmin.example.com
SUB_STORE_ADMIN_ALLOWED_EMAILS=your-email@example.com

# Cloudflare API 凭证（用于 KV 操作）
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_KV_NAMESPACE_ID=your_kv_namespace_id_here
